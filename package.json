{
  "name": "protorig.app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "conc -n 'vite,wisp' -c 'green,blue' 'vite' 'dotenv run node wisp-server.mjs'",
    "build": "vite build && bun build wisp-server.mjs --compile --outfile ./dist/wisp-server",
    "preview": "vite preview",
    "test": "vitest run",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json"
  },
  "devDependencies": {
    "@iconify/svelte": "^5.2.1",
    "@mercuryworkshop/wisp-js": "^0.4.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "@tsconfig/svelte": "^5.0.6",
    "@types/he": "^1.2.3",
    "@types/node": "^24.10.1",
    "autoprefixer": "^10.4.27",
    "bun": "^1.3.10",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "express": "^5.2.1",
    "he": "^1.2.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.8",
    "svelte": "^5.45.2",
    "svelte-check": "^4.3.4",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-jsonx": "^1.2.2",
    "vitest": "^4.0.18",
    "ws": "^8.19.0"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@tursodatabase/database-wasm": "^0.5.1",
    "libcurl.js": "^0.7.4"
  }
}
